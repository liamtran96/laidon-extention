# Comma-separated allowlist of upstream hostnames that may be set as `svUrl`
# via POST /__config. Matches exactly or by domain suffix.
# Leave unset to allow any https:// host (http:// is only ever allowed for
# localhost / 127.0.0.1).
ALLOWED_SV_HOSTS=cfapps.br10.hana.ondemand.com,hana.ondemand.com
