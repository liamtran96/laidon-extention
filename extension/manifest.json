{
  "manifest_version": 3,
  "name": "ProxyHub Connector",
  "version": "1.0",
  "description": "Auto-captures session headers from target domains and sends them to local proxyhub",
  "permissions": [
    "webRequest",
    "storage",
    "alarms",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ProxyHub Connector"
  }
}
