{
  "manifest_version": 2,
  "name": "ProxyHub Connector",
  "version": "1.0",
  "description": "Auto-captures session headers from target domains and sends them to local proxyhub",
  "permissions": [
    "webRequest",
    "storage",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "ProxyHub Connector"
  }
}
